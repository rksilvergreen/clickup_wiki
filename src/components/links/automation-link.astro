---
/**
 * AutomationLink — link to an automation section.
 *
 * Wraps doc-shell's Link. Pass the section `id` directly as `to`.
 * Example: <AutomationLink to="sec-4-2-4-3-1">Events</AutomationLink>
 */
import Link from "doc-shell/components/link/link.astro";

interface Props {
  to: string;
}

const { to } = Astro.props;
---

<Link to={to} class="automation-link"><slot /></Link>

<style is:global>
  :root {
    --doc-link-automations: #eab308;
    --doc-link-automations-hover: #facc15;
  }
  [data-theme="light"] {
    --doc-link-automations: #a16207;
    --doc-link-automations-hover: #ca8a04;
  }
  .document a.automation-link,
  .document a.automation-link:visited {
    color: var(--doc-link-automations);
  }
  .document a.automation-link:hover {
    color: var(--doc-link-automations-hover);
    text-decoration: underline;
  }
</style>

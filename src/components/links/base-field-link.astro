---
/**
 * BaseFieldLink — link to a row in the base-scope table.
 *
 * Wraps doc-shell's Link, prepending "base-scope-row-" to the `to` value.
 * Example: <BaseFieldLink to="status">Status</BaseFieldLink>
 *          → href="#base-scope-row-status"
 */
import Link from "doc-shell/components/link/link.astro";

interface Props {
  to: string;
}

const { to } = Astro.props;
---

<Link to={`base-scope-row-${to}`} class="base-field-link"><slot /></Link>

<style is:global>
  :root {
    --doc-link-base-scope: #7da0f0;
  }
  [data-theme="light"] {
    --doc-link-base-scope: #2563eb;
  }
  /* Include :visited — `.document a:visited` in link.css would otherwise win and wash out the accent. */
  .document a.base-field-link,
  .document a.base-field-link:visited {
    color: var(--doc-link-base-scope);
  }
</style>

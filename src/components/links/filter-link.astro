---
/**
 * FilterLink — link to a filter section.
 *
 * Wraps doc-shell's Link, prepending "filter-" to the `to` value.
 * The target Section must declare alias="filter-{name}".
 * Example: <FilterLink to="status">Status Filter</FilterLink>
 *          → href="#filter-status"
 */
import Link from "doc-shell/components/link/link.astro";

interface Props {
  to: string;
}

const { to } = Astro.props;
---

<Link to={`filter-${to}`} class="filter-link"><slot /></Link>

<style is:global>
  a.filter-link { color: var(--doc-link-filter); }
  a.filter-link:hover {
    color: var(--doc-link-filter-hover);
    text-decoration: underline;
  }
</style>

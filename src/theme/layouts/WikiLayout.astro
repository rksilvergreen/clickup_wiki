---
import '../styles/document.css';
import TOC from '../components/TOC.astro';
import NavControls from '../components/NavControls.astro';
import StickyToggle from '../components/StickyToggle.astro';

export interface TocEntry {
  id: string;
  text: string;
  children?: TocEntry[];
}

interface Props {
  title: string;
  tocEntries: TocEntry[];
}

const { title, tocEntries } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
    rel="stylesheet"
  />
  <script is:inline>
    (function(){var t=localStorage.getItem('wiki-theme');if(t==='light')document.documentElement.setAttribute('data-theme','light')})();
  </script>
</head>
<body>
  <div class="doc-header-strip"></div>
  <StickyToggle />
  <div class="doc-layout">
    <nav class="doc-toc" aria-label="Table of contents">
      <NavControls />
      <div class="doc-toc-inner">
        <TOC entries={tocEntries} />
      </div>
      <div class="doc-toc-resize" aria-hidden="true"></div>
    </nav>
    <main class="document doc-content">
      <slot />
    </main>
  </div>
  <footer class="doc-footer">{title}</footer>

  <script src="../scripts/toc-resize.ts"></script>
  <script src="../scripts/toc-active.ts"></script>
  <script src="../scripts/sticky-headers.ts"></script>
  <script src="../scripts/row-navigation.ts"></script>
  <script src="../scripts/row-tooltip.ts"></script>
  <script src="../scripts/schema-table-height.ts"></script>
  <script src="../scripts/section-tooltip.ts"></script>
  <script src="../scripts/nav-history.ts"></script>
  <script src="../scripts/field-status-tips.ts"></script>
  <script src="../scripts/theme-toggle.ts"></script>
</body>
</html>

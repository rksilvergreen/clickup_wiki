---
export interface TocEntry {
  id: string;
  text: string;
  children?: TocEntry[];
}

interface Props {
  entries: TocEntry[];
}

interface FlatEntry {
  id: string;
  num: string;
  name: string;
  depth: number;
}

function flatten(entries: TocEntry[], depth: number = 0): FlatEntry[] {
  const result: FlatEntry[] = [];
  for (const entry of entries) {
    const match = entry.text.match(/^([\d.]+)\s+(.+)$/);
    result.push({
      id: entry.id,
      num: match ? match[1] : '',
      name: match ? match[2] : entry.text,
      depth,
    });
    if (entry.children) {
      result.push(...flatten(entry.children, depth + 1));
    }
  }
  return result;
}

const { entries } = Astro.props;
const flat = flatten(entries);
---
<ul class="doc-toc-list">
  {flat.map((entry) => (
    <li>
      <a href={`#${entry.id}`} data-depth={entry.depth}>
        <span class="toc-num">{entry.num}</span>
        <span class="toc-name" style={`padding-left: ${entry.depth * 0.5}rem`}>{entry.name}</span>
      </a>
    </li>
  ))}
</ul>

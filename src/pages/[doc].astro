---
import { getCollection } from "astro:content";
import DocLayout from "doc-shell/layouts/DocLayout.astro";
import { siteTitle, documents } from "clickup_wifi/wiki.config";
import { tocs } from "clickup_wifi/content/toc";
import StatusLink from "clickup_wifi/components/StatusLink.astro";
import "clickup_wifi/styles/clickup.css";

export function getStaticPaths() {
  return documents.map((d) => ({
    params: { doc: d.slug },
    props: { document: d },
  }));
}

const { document } = Astro.props;
const sections = await getCollection("documents");
const docSections = sections
  .filter((s) => s.id.startsWith(document.slug + "/"))
  .sort((a, b) => a.data.order - b.data.order);

const renderedSections = await Promise.all(
  docSections.map(async (section) => {
    const { Content } = await section.render();
    return { id: section.id, Content };
  }),
);
---

<DocLayout
  title={document.title}
  tocEntries={tocs[document.slug] || []}
  documents={documents}
  currentSlug={document.slug}
  siteTitle={siteTitle}
>
  {renderedSections.map(({ Content }) => <Content components={{ StatusLink }} />)}
</DocLayout>
<script src="clickup_wifi/scripts/field-status-tips.ts"></script>
<script src="clickup_wifi/scripts/sync-table-cols.ts"></script>

---
import { getCollection } from "astro:content";
import DocLayout, {
  Section,
  Link,
  LinkTarget,
  Table,
  THead,
  TBody,
  TR,
  TH,
  TD,
  extractToc,
} from "doc-shell/layouts/doc-layout";
import { documents } from "../content/documents";
import Status from "clickup_wiki/components/Status/Status.astro";
import StatusLink from "clickup_wiki/components/Status/StatusLink.astro";
import "clickup_wiki/components/Status/status.css";
import "clickup_wiki/styles/clickup.css";

export function getStaticPaths() {
  return documents.map((d) => ({
    params: { doc: d.slug },
    props: { document: d },
  }));
}

const { document } = Astro.props;
const sections = await getCollection("documents");
const docSections = sections
  .filter((s) => s.id.startsWith(document.slug + "/"))
  .sort((a, b) => a.data.order - b.data.order);

const toc = extractToc(docSections.map((s) => s.body));

const renderedSections = await Promise.all(
  docSections.map(async (section) => {
    const { Content } = await section.render();
    return { id: section.id, Content };
  }),
);
---

<DocLayout
  documents={documents}
  slug={document.slug}
  toc={toc}
>
  {
    renderedSections.map(({ Content }) => (
      <Content
        components={{
          Section,
          Link,
          LinkTarget,
          Table,
          THead,
          TBody,
          TR,
          TH,
          TD,
          Status,
          StatusLink,
        }}
      />
    ))
  }
</DocLayout>
<script src="clickup_wiki/scripts/field-status-tips.ts"></script>
<script src="clickup_wiki/scripts/sync-table-cols.ts"></script>

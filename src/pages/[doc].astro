---
import DocLayout, { getDocumentPaths } from "doc-shell/layouts/doc-layout";
import Status from "@components/status/status.astro";
import StatusSubgroup from "@components/status-subgroup/status-subgroup.astro";
import StatusTrigger from "@components/status-trigger/status-trigger.astro";
import StatusLink from "@components/links/status-link.astro";
import StatusTriggerLink from "@components/links/status-trigger-link.astro";
import BaseFieldLink from "@components/links/base-field-link.astro";
import FieldTypeLink from "@components/links/field-type-link.astro";
import CustomFieldLink from "@components/links/custom-field-link.astro";
import TaskTypeFieldLink from "@components/links/task-type-field-link.astro";
import TaskTypeLink from "@components/links/task-type-link.astro";
import StatusGroupLink from "@components/links/status-group-link.astro";
import FilterLink from "@components/links/filter-link.astro";
import AutomationLink from "@components/links/automation-link.astro";
import ViewLink from "@components/links/view-link.astro";
import LocationLink from "@components/links/location-link.astro";
import Tag from "@components/tag/tag.astro";
import HierarchyTree from "@components/hierarchy-tree/hierarchy-tree.astro";
import Rule from "@components/rule-block/rule.astro";
import Entry from "@components/rule-block/entry.astro";
import Group from "@components/rule-block/group.astro";
import GroupItem from "@components/rule-block/group-item.astro";
import Nested from "@components/rule-block/nested.astro";
import "clickup_wiki/styles/clickup.css";

export const getStaticPaths = getDocumentPaths;
const { entry, allDocs } = Astro.props;
const components = {
  Status,
  StatusSubgroup,
  StatusTrigger,
  StatusLink,
  StatusTriggerLink,
  BaseFieldLink,
  FieldTypeLink,
  CustomFieldLink,
  TaskTypeFieldLink,
  TaskTypeLink,
  StatusGroupLink,
  FilterLink,
  AutomationLink,
  ViewLink,
  LocationLink,
  Tag,
  HierarchyTree,
  Rule,
  Entry,
  Group,
  GroupItem,
  Nested,
};
---

<DocLayout entry={entry} allDocs={allDocs} components={components} />
